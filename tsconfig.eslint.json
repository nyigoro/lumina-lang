{
  "extends": "./tsconfig.json",
  "include": [
    "src/**/*",
    "cli/**/*",
    "docs-site/**/*.ts",
    "playground/**/*.ts",
    "scripts/**/*.ts",
    "tests/**/*",
    "types/**/*",
    "*.config.js",
    "*.config.ts",
    "jest.config.ts",
    "prettier.config.cjs",
    "eslint.config.js"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build"
  ]
}
