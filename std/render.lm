import { render } from "@std";

pub fn text(value: any) -> VNode {
  render.text(value)
}

pub fn fragment(children: any) -> VNode {
  render.fragment(children)
}

pub fn vnode(tag: string, attrs: any, children: any) -> VNode {
  render.element(tag, attrs, children)
}

pub fn component<P>(renderFn: fn(P) -> VNode, props: P) -> VNode {
  render.component(renderFn, props)
}

pub fn component_keyed<P>(renderFn: fn(P) -> VNode, props: P, key: any) -> VNode {
  render.component_keyed(renderFn, props, key)
}

pub fn createContext<T>(defaultValue: T) -> any {
  render.create_context(defaultValue)
}

pub fn createRequiredContext() -> any {
  render.create_required_context()
}

pub fn withContext<T>(context: any, value: T, renderChildren: fn() -> VNode) -> VNode {
  render.with_context(context, value, renderChildren)
}

pub fn useContext<T>(context: any) -> T {
  render.use_context(context)
}

pub fn state<T>(initial: T) -> Signal<T> {
  render.state(initial)
}

pub fn remember<T>(compute: fn() -> T) -> T {
  render.remember(compute)
}

pub fn createResource<T>(key: any, loader: fn() -> Promise<T>, options: any) -> any {
  render.createResource(key, loader, options)
}

