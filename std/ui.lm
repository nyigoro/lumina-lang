import {
  props_class,
  props_merge,
  transitionPresence,
  vnode,
  tabsList,
  tabsTrigger,
  tabsPanel,
  dialogOverlay,
  dialogContent,
  toastContent
} from "@std/render";

pub fn button(props: any, children: any) -> VNode {
  vnode(
    "button",
    props_merge(
      props_class("inline-flex items-center justify-center rounded-xl bg-slate-900 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-slate-800 focus:outline-none focus:ring-2 focus:ring-sky-400"),
      props
    ),
    children
  )
}

pub fn input(props: any) -> VNode {
  vnode(
    "input",
    props_merge(
      props_class("w-full rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm outline-none transition focus:border-sky-400 focus:ring-2 focus:ring-sky-100"),
      props
    ),
    []
  )
}

pub fn card(props: any, children: any) -> VNode {
  vnode(
    "div",
    props_merge(
      props_class("rounded-2xl border border-slate-200 bg-white/90 p-6 shadow-xl shadow-slate-200/60 backdrop-blur"),
      props
    ),
    children
  )
}

pub fn tabsListStyled(props: any, renderChildren: fn() -> any) -> VNode {
  tabsList(
    props_merge(
      props_class("inline-flex rounded-2xl bg-slate-100 p-1"),
      props
    ),
    renderChildren
  )
}

pub fn tabsTriggerStyled(value: string, props: any, children: any) -> VNode {
  tabsTrigger(
    value,
    props_merge(
      props_class("rounded-xl px-4 py-2 text-sm font-medium text-slate-600 transition data-[state=active]:bg-white data-[state=active]:text-slate-950 data-[state=active]:shadow-sm"),
      props
    ),
    children
  )
}

pub fn tabsPanelStyled(value: string, props: any, children: any) -> VNode {
  tabsPanel(
    value,
    props_merge(
      props_class("rounded-2xl border border-slate-200 bg-white p-5 shadow-sm"),
      props
    ),
    children
  )
}

pub fn dialogOverlayStyled(props: any) -> VNode {
  dialogOverlay(
    props_merge(
      props_class("fixed inset-0 bg-slate-950/55 backdrop-blur-sm"),
      props
    )
  )
}

pub fn dialogContentStyled(props: any, children: any) -> VNode {
  dialogContent(
    props_merge(
      props_class("fixed left-1/2 top-1/2 w-[min(92vw,34rem)] -translate-x-1/2 -translate-y-1/2 rounded-3xl border border-slate-200 bg-white p-6 shadow-2xl shadow-slate-950/20"),
      props
    ),
    children
  )
}

pub fn toastContentStyled(props: any, children: any) -> VNode {
  toastContent(
    props_merge(
      props_class("fixed bottom-6 right-6 w-[min(92vw,24rem)] rounded-2xl bg-slate-950 px-4 py-3 text-white shadow-2xl"),
      props
    ),
    children
  )
}

pub fn presenceCard(open: Signal<bool>, props: any, children: any) -> VNode {
  transitionPresence(
    open,
    props_merge(
      props_class("will-change-transform transition duration-200 ease-out data-[transition-state=enter-from]:translate-y-2 data-[transition-state=enter-from]:opacity-0 data-[transition-state=enter-to]:translate-y-0 data-[transition-state=enter-to]:opacity-100 data-[transition-state=exit-from]:translate-y-0 data-[transition-state=exit-from]:opacity-100 data-[transition-state=exit-to]:translate-y-2 data-[transition-state=exit-to]:opacity-0"),
      props
    ),
    180,
    || children
  )
}
