import { render } from "@std";

pub fn group(value: Signal<string>, props: any, renderChildren: fn() -> any) -> VNode {
  render.radioGroup(value, props, renderChildren)
}

pub fn item(value: string, props: any, renderChildren: fn() -> any) -> VNode {
  render.radioItem(value, props, renderChildren)
}

pub fn indicator(props: any, children: any) -> VNode {
  render.radioIndicator(props, children)
}
